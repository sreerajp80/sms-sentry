<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_main_layout"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@android:color/transparent"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:gravity="center_vertical">

    <!-- Circle Icon on the left -->
    <FrameLayout
        android:id="@+id/circle_icon_container"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginRight="12dp"
        android:layout_gravity="center_vertical">
        <ImageView
            android:id="@+id/circle_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/circle_blue_outline"/>
        <TextView
            android:id="@+id/circle_icon_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="O"
            android:textColor="#3AA0FF"
            android:textStyle="bold"
            android:textSize="18sp"/>
    </FrameLayout>

    <!-- Text area in the center -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_gravity="center_vertical"
        android:layout_marginRight="8dp">

        <TextView
            android:id="@+id/otp_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12345"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/otp_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTP from Google"
            android:textColor="#A0B0C0"
            android:textSize="11sp"
            android:ellipsize="end"
            android:singleLine="true"/>
    </LinearLayout>

    <!-- Quick action buttons on the right -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Copy button -->
        <LinearLayout
            android:id="@+id/btn_copy"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/img_copy"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_copy"/>

            <TextView
                android:id="@+id/txt_copy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy"
                android:textColor="#3AA0FF"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Delete button -->
        <LinearLayout
            android:id="@+id/btn_delete"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/img_delete"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_delete"/>

            <TextView
                android:id="@+id/txt_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete"
                android:textColor="#3AA0FF"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
